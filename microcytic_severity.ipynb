   "metadata": {},
   "outputs": [],
   "source": [
    "MCV_ref=90\n",
    "MCH_ref=30\n",
    "MCHC_ref=34\n",
    "RBC_ref=13\n",
    "HGB_ref=14"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 408,
   "id": "bfae7d3c",
   "metadata": {},
   "outputs": [],
   "source": [
    "D_MCV = np.maximum((MCV_ref - df_clean['MCV']) / MCV_ref, 0)\n",
    "D_MCH = np.maximum((MCH_ref - df_clean['MCH']) / MCH_ref, 0)\n",
    "D_MCHC = np.maximum((MCHC_ref - df_clean['MCHC']) / MCHC_ref, 0)\n",
    "D_RBC = np.maximum((df_clean['RBC'] - RBC_ref) / RBC_ref, 0)\n",
    "D_HGB = np.maximum((HGB_ref - df_clean['HGB']) / HGB_ref, 0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 409,
   "id": "dec2d964",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_clean[\"Severity_raw\"] = 10*(\n",
    "    0.25 * D_MCV +\n",
    "    0.20 * D_MCH +\n",
    "    0.20 * D_MCHC +\n",
    "    0.15 * D_RBC +\n",
    "    0.20 * D_HGB\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 410,
   "id": "4d991653",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import MinMaxScaler\n",
    "scaler = MinMaxScaler(feature_range=(0,10))\n",
    "\n",
    "df_clean[\"Severity\"] = scaler.fit_transform(df_clean[[\"Severity_raw\"]])"
   ]
  },
